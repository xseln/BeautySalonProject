@model BeautySalonProject.Areas.Admin.ViewModels.Dashboard.DashboardVm
@{
    ViewData["Title"] = "Админ панел";
}

<div class="container my-5">

    <div class="sh-page-hero text-center mb-4">
        <div class="sh-hero-kicker">SH Beauty Studio</div>
        <h1 class="sh-hero-title">Админ панел</h1>
        <div class="sh-hero-desc">Бърз преглед на запитвания, часове и активност</div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="sh-admin-card">
                <div class="sh-admin-card-title">Нови запитвания</div>
                <div class="sh-admin-card-value">@Model.NewInquiriesCount</div>
                <div class="sh-admin-card-sub">чакащи обработка</div>
                <div class="mt-3">
                    <a class="btn sh-btn-book btn-sm" asp-area="Admin" asp-controller="Inquiries" asp-action="Index">Отвори</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="sh-admin-card">
                <div class="sh-admin-card-title">Днешни часове</div>
                <div class="sh-admin-card-value">@Model.TodayAppointmentsCount</div>
                <div class="sh-admin-card-sub">записвания за днес</div>
                <div class="mt-3">
                    <a class="btn sh-btn-book btn-sm" asp-area="Admin" asp-controller="Appointments" asp-action="Index">Отвори</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="sh-admin-card">
                <div class="sh-admin-card-title">Най-търсени услуги</div>
                <div class="sh-admin-card-sub">топ 5 по записвания</div>

                @if (Model.TopServices.Count == 0)
                {
                        <div class="text-muted mt-2">Няма данни все още.</div>
                }
                else
                {
                        <ul class="sh-admin-toplist mt-2">
                        @foreach (var s in Model.TopServices)
                        {
                                    <li>
                                        <span>@s.Title</span>
                                        <span class="badge sh-admin-badge">@s.Count</span>
                                    </li>
                        }
                        </ul>
                }
            </div>
        </div>
    </div>

    <!-- Tables -->
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="sh-content-card">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h3 class="sh-section-title mb-0">Последни запитвания</h3>
                    <a class="sh-admin-link" asp-area="Admin" asp-controller="Inquiries" asp-action="Index">виж всички</a>
                </div>

                @if (Model.LatestInquiries.Count == 0)
                {
                        <div class="text-muted">Няма запитвания.</div>
                }
                else
                {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr class="text-muted small">
                                        <th>Клиент</th>
                                        <th>Услуга</th>
                                        <th class="text-end">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var i in Model.LatestInquiries)
                                {
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@i.FullName</div>
                                                    <div class="text-muted small">@i.Phone</div>
                                                </td>
                                                <td>
                                                    <div>@i.ServiceText</div>
                                                    <div class="text-muted small">
                                                @(i.PreferredDateTime.HasValue ? i.PreferredDateTime.Value.ToString("dd.MM.yyyy HH:mm") : "—")
                                                    </div>
                                                </td>
                                                <td class="text-end">
                                                    <span class="badge @GetInquiryBadge(i.Status)">@GetInquiryText(i.Status)</span>
                                                </td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="sh-content-card">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h3 class="sh-section-title mb-0">Днешен график</h3>
                    <a class="sh-admin-link" asp-area="Admin" asp-controller="Appointments" asp-action="Index">виж всички</a>
                </div>

                @if (Model.TodaysSchedule.Count == 0)
                {
                        <div class="text-muted">Няма записвания за днес.</div>
                }
                else
                {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr class="text-muted small">
                                        <th>Час</th>
                                        <th>Услуга</th>
                                        <th>Служител</th>
                                        <th class="text-end">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var a in Model.TodaysSchedule)
                                {
                                            <tr>
                                                <td class="fw-semibold">@a.StartAt.ToString("HH:mm")</td>
                                                <td>
                                                    <div>@a.ServiceName</div>
                                                    <div class="text-muted small">@a.VariantName</div>
                                                </td>
                                                <td>@a.EmployeeName</td>
                                                <td class="text-end">
                                                    <span class="badge @GetApptBadge(a.Status)">@GetApptText(a.Status)</span>
                                                </td>
                                            </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetInquiryText(byte s) => s switch
    {
        0 => "Ново",
        1 => "Одобрено",
        2 => "Отказано",
        _ => "—"
    };

    string GetInquiryBadge(byte s) => s switch
    {
        0 => "sh-badge sh-badge-warn",
        1 => "sh-badge sh-badge-ok",
        2 => "sh-badge sh-badge-bad",
        _ => "sh-badge"
    };

    string GetApptText(byte s) => s switch
    {
        0 => "Чака",
        1 => "Потвърден",
        2 => "Приключен",
        3 => "Отказан",
        _ => "—"
    };

    string GetApptBadge(byte s) => s switch
    {
        0 => "sh-badge sh-badge-warn",
        1 => "sh-badge sh-badge-ok",
        2 => "sh-badge sh-badge-ok",
        3 => "sh-badge sh-badge-bad",
        _ => "sh-badge"
    };
}
