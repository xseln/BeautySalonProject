@model BeautySalonProject.Areas.Admin.ViewModels.Services.AdminServiceIndexVm
@{
    ViewData["Title"] = "Услуги и цени";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="sh-admin-page">

    <div class="sh-admin-head mb-4">
        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <div>
                <h1 class="sh-admin-title mb-1">Услуги и цени</h1>
                <div class="sh-admin-subtitle">Управление на услуги, служители и варианти</div>
            </div>

            <a class="btn sh-btn-book"
               asp-area="Admin" asp-controller="Services" asp-action="Create">+ Нова услуга</a>
        </div>
    </div>

    <div class="sh-admin-card mb-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Категория</label>
                <select class="form-select" name="categoryId">
                    <option value="">Всички</option>
                    @foreach (var c in Model.Categories)
                    {
                            <option value="@c.CategoryId" selected="@(Model.CategoryId == c.CategoryId)">
                            @c.Name
                            </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Активност</label>
                <select class="form-select" name="active">
                    <option value="">Всички</option>
                    <option value="true" selected="@(Model.Active == true)">Активни</option>
                    <option value="false" selected="@(Model.Active == false)">Неактивни</option>
                </select>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn sh-btn-book w-100">Филтрирай</button>
                <a class="btn btn-outline-secondary w-100"
                   asp-area="Admin" asp-controller="Services" asp-action="Index">Изчисти</a>
            </div>
        </form>
    </div>

    <div class="sh-admin-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr class="text-muted small">
                        <th>Категория</th>
                        <th>Услуга</th>
                        <th>Служител</th>
                        <th>Цена</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Items)
                    {
                            <tr>
                                <td class="text-muted">@s.CategoryName</td>
                                <td class="fw-semibold">@s.Name</td>
                                <td>@s.EmployeeName</td>
                                <td>
                                @{
                                    var min = s.MinPrice;
                                    var max = s.MaxPrice;

                                    string priceText =
                                        !min.HasValue ? "—" :
                                        (min == max ? $"{min.Value:0.##} €" : $"{min.Value:0.##} – {max!.Value:0.##} €");
                                }
                                    <span class="fw-semibold">@priceText</span>
                                </td>

                                <td>
                                @if (s.IsActive)
                                {
                                            <span class="badge text-bg-success">Активна</span>
                                }
                                else
                                {
                                            <span class="badge text-bg-secondary">Неактивна</span>
                                }
                                </td>

                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-area="Admin" asp-controller="Services" asp-action="Edit" asp-route-id="@s.ServiceId">
                                        Редакция
                                    </a>

                                    <a class="btn btn-sm btn-outline-dark"
                                       asp-area="Admin" asp-controller="ServiceVariants" asp-action="Index" asp-route-serviceId="@s.ServiceId">
                                        Варианти
                                    </a>
                                </td>
                            </tr>
                    }

                    @if (!Model.Items.Any())
                    {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Няма услуги по избрания филтър.</td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
