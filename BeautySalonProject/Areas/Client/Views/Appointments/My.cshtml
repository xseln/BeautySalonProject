@model BeautySalonProject.Areas.Client.ViewModels.Appointments.ClientMyAppointmentsVm

@{
    ViewData["Title"] = "Моите часове";
}

<div class="sh-page-hero mb-4 text-center">
    <div class="sh-brand-wrapper">
        <div class="sh-slogan-wrap justify-content-center">
            <span class="line"></span>
            <span class="sh-slogan">SH Beauty Studio</span>
            <span class="line"></span>
        </div>

        <h1 class="sh-hero-title mt-2">Моите часове</h1>

        <div class="sh-hero-desc sh-muted">
            Преглед на предстоящи и минали посещения
        </div>
    </div>
</div>


<!-- Upcoming -->
<div class="sh-form-card mb-4">

    <div class="sh-section-title">
        <i class="fa-regular fa-calendar-check me-2"></i>
        Предстоящи часове
    </div>

    @if (!Model.Upcoming.Any())
    {
        <div class="sh-empty">Нямате предстоящи часове.</div>
    }
    else
    {
    <div class="row g-3">

            @foreach (var a in Model.Upcoming)
            {
        <div class="col-md-6 col-lg-4">

        <div class="sh-appointment-card">

        <div class="sh-appointment-service">
                            @a.ServiceName – @a.VariantName
        </div>

        <div class="sh-appointment-info">

        <div>
        <i class="fa-regular fa-user me-2"></i>
                                @a.EmployeeName
        </div>

        <div>
        <i class="fa-regular fa-calendar me-2"></i>
                                @a.StartAt.ToString("dd.MM.yyyy")
        </div>

        <div>
        <i class="fa-regular fa-clock me-2"></i>
                                @a.StartAt.ToString("HH:mm")
        </div>

        <div>
        <i class="fa-solid fa-tag me-2"></i>
                                @a.FinalPrice.ToString("0.00") €
        </div>

        </div>

        <div class="sh-appointment-actions">

        <span class="sh-status sh-status-booked">
                                @a.StatusText
        </span>

                            @if (a.CanCancel)
                            {
                <div class="d-flex gap-2">

                    <a class="btn sh-btn-edit btn-sm"
                       asp-area="Client"
                       asp-controller="Appointments"
                       asp-action="Edit"
                       asp-route-id="@a.AppointmentId">
                        Редактирай
                    </a>
                                    @if (DateTime.Now >= a.StartAt.AddHours(-2))
                                    {
                    <span class="text-muted small">
                        Редакцията е затворена
                    </span>
                                    }
                    <form asp-action="Cancel"
                          asp-controller="Appointments"
                          asp-area="Client"
                          method="post">

                        <input type="hidden" name="id" value="@a.AppointmentId" />

                        <button class="btn sh-btn-cancel btn-sm">
                            Откажи
                        </button>

                    </form>

                </div>
                            }

        </div>

        </div>

        </div>
            }

    </div>
    }

</div>


<!-- Past -->
<div class="sh-form-card">

<div class="sh-section-title">
<i class="fa-regular fa-clock me-2"></i>
Минали посещения
</div>

    @if (!Model.Past.Any())
    {
    <div class="sh-empty">Нямате минали посещения.</div>
    }
    else
    {
    <div class="row g-3">

            @foreach (var a in Model.Past)
            {
        <div class="col-md-6 col-lg-4">

        <div class="sh-appointment-card sh-past">

        <div class="sh-appointment-service">
                            @a.ServiceName – @a.VariantName
        </div>

        <div class="sh-appointment-info">

        <div>
        <i class="fa-regular fa-user me-2"></i>
                                @a.EmployeeName
        </div>

        <div>
        <i class="fa-regular fa-calendar me-2"></i>
                                @a.StartAt.ToString("dd.MM.yyyy HH:mm")
        </div>

        <div>
        <i class="fa-solid fa-tag me-2"></i>
                                @a.FinalPrice.ToString("0.00") €
        </div>

        </div>

        <span class="sh-status sh-status-completed">
                            @a.StatusText
        </span>

        </div>

        </div>
            }

    </div>
    }

</div>