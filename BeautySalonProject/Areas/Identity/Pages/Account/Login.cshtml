@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">

            <div class="sh-form-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <a class="btn sh-btn-ghost" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-arrow-left me-2"></i> Начало
                    </a>
                    <a class="sh-btn-link" asp-area="Identity" asp-page="/Account/Register">
                        Нямаш профил? Регистрация
                    </a>
                </div>

                <h2 class="sh-section-title mb-1">Вход</h2>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label sh-muted">Email</label>
                        <input asp-for="Input.Email" class="form-control sh-input" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label sh-muted">Парола</label>
                        <input asp-for="Input.Password" class="form-control sh-input" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                    </div>

                    <button type="submit" class="btn sh-btn-book w-100">
                        <i class="fa-solid fa-right-to-bracket me-2"></i> Вход
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}