@page
@model BeautySalonProject.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">

            <div class="sh-form-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <a class="btn sh-btn-ghost" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-arrow-left me-2"></i> Начало
                    </a>

                    <a class="sh-btn-link" asp-area="Identity" asp-page="/Account/Login">
                        Вече имаш профил? Вход
                    </a>
                </div>

                <h2 class="sh-section-title mb-1">Създай профил</h2>
                <div class="sh-muted mb-3">Попълни данните и запази час още по-бързо.</div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label sh-muted">Име</label>
                            <input asp-for="Input.FirstName" class="form-control sh-input" />
                            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label sh-muted">Фамилия</label>
                            <input asp-for="Input.LastName" class="form-control sh-input" />
                            <span asp-validation-for="Input.LastName" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label sh-muted">Телефон</label>
                            <input asp-for="Input.PhoneNumber" class="form-control sh-input" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label sh-muted">Email</label>
                            <input asp-for="Input.Email" class="form-control sh-input" autocomplete="username" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label sh-muted">Парола</label>
                            <input asp-for="Input.Password" class="form-control sh-input" autocomplete="new-password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label sh-muted">Повтори парола</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control sh-input" autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn sh-btn-book w-100 mt-4">
                        <i class="fa-solid fa-user-plus me-2"></i> Регистрация
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}