@{
    ViewData["Title"] = "Контакти";
}

<div class="container my-4">
    <div class="sh-page-hero mb-4 text-center">
        <div class="sh-hero-kicker">SH Beauty Studio</div>
        <h1 class="about-title">Контакти</h1>
        <div class="sh-hero-subtitle">Свържи се с нас</div>
    </div>

    <div class="sh-content-card">
        <div class="row g-4">
            <div class="col-md-6">
                <h3 class="sh-section-title">Адрес</h3>
                <div>гр. София, ул. „Граф Игнатиев“ №27</div>
                <div class="mt-2"><b>Тел:</b> 088 214 9331</div>
                <div><b>Email:</b> shbeautystudioo@gmail.com</div>
            </div>

            <div class="col-md-6">
                <h3 class="sh-section-title">Социални мрежи</h3>

                <div class="d-flex flex-column gap-2">
                    <a class="sh-social" href="#" target="_blank">
                        <span class="sh-social-icon">📘</span> Facebook: <b>SH Beauty Studio</b>
                    </a>
                    <a class="sh-social" href="#" target="_blank">
                        <span class="sh-social-icon">📷</span> Instagram: <b>shbeautystudio</b>
                    </a>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                        <a class="btn sh-btn-book" asp-area="Client" asp-controller="Appointments" asp-action="Create">Запази своя час</a>
            }
            else
            {
                        <a class="btn sh-btn-book" asp-controller="Inquiries" asp-action="Create">Запази своя час</a>
            }
        </div>
    </div>
</div>
