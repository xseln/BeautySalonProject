@model BeautySalonProject.ViewModels.InquiryCreateVm
@{
    ViewData["Title"] = "Запитване";
}

<div class="container my-4">
    <div class="sh-page-hero mb-4">
        <div class="text-center">
            <h1 class="about-title">Запазете своя час</h1>
            <div class="sh-hero-subtitle">Изпратете своето запитване</div>
        </div>
    </div>

    @if (TempData["Ok"] != null)
    {
            <div class="alert alert-success">@TempData["Ok"]</div>
    }

    <div class="sh-form-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label">Име</label>
                    <input asp-for="FirstName" class="form-control sh-input" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label">Фамилия</label>
                    <input asp-for="LastName" class="form-control sh-input" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label">Телефон</label>
                    <input asp-for="Phone" class="form-control sh-input" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control sh-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="CategoryId" class="form-label">Категория</label>
                    <select asp-for="CategoryId"
                            asp-items="Model.Categories"
                            class="form-select sh-input"
                            id="categorySelect">
                        <option value="">-- Изберете категория --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="ServiceVariantId" class="form-label">Услуга</label>
                    <select asp-for="ServiceVariantId"
                            class="form-select sh-input"
                            id="variantSelect"
                            disabled>
                        <option value="">-- Първо изберете категория --</option>
                    </select>
                    <span asp-validation-for="ServiceVariantId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PreferredDateTime" class="form-label">Предпочитана дата и час</label>
                    <input asp-for="PreferredDateTime" type="datetime-local" class="form-control sh-input" />
                    <span asp-validation-for="PreferredDateTime" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Note" class="form-label">Бележка</label>
                    <textarea asp-for="Note" rows="4" class="form-control sh-input"
                              placeholder="Напр. удобен часови диапазон, допълнителни детайли..."></textarea>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 flex-wrap justify-content-center">
                <button type="submit" class="btn sh-btn-book">Изпрати запитване</button>
                <a asp-controller="Home" asp-action="Index" class="btn sh-btn-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />

        <script>
            const categorySelect = document.getElementById("categorySelect");
            const variantSelect = document.getElementById("variantSelect");

            categorySelect.addEventListener("change", async function () {
                const categoryId = this.value;

                variantSelect.innerHTML = "";
                variantSelect.disabled = true;

                if (!categoryId) {
                    variantSelect.innerHTML = `<option value="">-- Първо изберете категория --</option>`;
                    return;
                }

                const res = await fetch(`/Inquiries/GetVariants?categoryId=${categoryId}`);
                const data = await res.json();

                variantSelect.innerHTML = `<option value="">-- Изберете услуга --</option>`;
                data.forEach(x => {
                    const opt = document.createElement("option");
                    opt.value = x.id;
                    opt.textContent = x.text;
                    variantSelect.appendChild(opt);
                });

                variantSelect.disabled = false;
            });
        </script>
}
