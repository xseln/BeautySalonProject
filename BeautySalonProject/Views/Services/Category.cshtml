@model BeautySalonProject.ViewModels.ServicesCategoryVm
@{
    ViewData["Title"] = Model.CategoryName;
}

<div class="container my-5">

    <div class="sh-page-hero text-center mb-5">
        <div class="sh-hero-kicker">SH Beauty Studio</div>
        <h1 class="sh-hero-title">@Model.CategoryName</h1>
        <div class="sh-hero-subtitle">Професионални услуги и прозрачни цени</div>

        <div class="mt-3">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                    <a class="btn sh-btn-book"
                       asp-area="Client"
                       asp-controller="Appointments"
                       asp-action="Create">
                        Запази своя час
                    </a>
            }
            else
            {
                    <a class="btn sh-btn-book"
                       asp-controller="Inquiries"
                       asp-action="Create">
                        Запази своя час
                    </a>
            }
        </div>
    </div>

    @foreach (var group in Model.Groups)
    {
            <div class="sh-content-card mb-5">

                <h3 class="sh-section-title text-center mb-4">
                @group.ServiceName
                </h3>

                <div class="table-responsive">
                    <table class="table sh-price-table align-middle">
                        <tbody>
                        @foreach (var item in group.Items)
                        {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.VariantName</div>
                                            <div class="text-muted small">
                                                Продължителност: @item.DurationMinutes мин
                                            </div>
                                        </td>

                                        <td class="text-end sh-price">
                                    @item.Price.ToString("0.##") €
                                        </td>

                                        <td class="text-end">
                                    @if (User.Identity?.IsAuthenticated ?? false)
                                    {
                                                    <a class="btn btn-sm sh-btn-book"
                                                       asp-area="Client"
                                                       asp-controller="Appointments"
                                                       asp-action="Create"
                                                       asp-route-variantId="@item.VariantId">
                                                        Запази час
                                                    </a>
                                    }
                                    else
                                    {
                                                    <a class="btn btn-sm sh-btn-book"
                                                       asp-controller="Inquiries"
                                                       asp-action="Create"
                                                       asp-route-variantId="@item.VariantId">
                                                        Запази час
                                                    </a>
                                    }
                                        </td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
    }

    <div class="text-center mt-5">
        <div class="sh-cta-box">
            <div class="mb-2 fw-semibold">Готови ли сте да запазите своя час?</div>

            <a class="btn sh-btn-book"
               asp-controller="Inquiries" asp-action="Create">
                Запази своя час
            </a>
        </div>
    </div>

</div>
