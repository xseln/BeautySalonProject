<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SH Beauty Salon</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BeautySalonProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>
   <header class="sh-topbar">

<nav class="navbar navbar-expand-lg sh-navbar">

<div class="container align-items-center">

<!-- LOGO -->

<a class="navbar-brand d-flex align-items-center gap-2 sh-brand"
   asp-controller="Home"
   asp-action="Index">

<img src="~/images/logo.png" class="sh-logo"/>

<div class="sh-brand-text">

<span class="sh-brand-title">
SH Beauty Studio
</span>

<div class="sh-slogan-wrap">

<span class="line"></span>

<span class="sh-slogan">
Chic & Unique
</span>

<span class="line"></span>

</div>

</div>

</a>



<!-- MENU -->

<ul class="navbar-nav mx-auto gap-4 sh-nav">

<li class="nav-item">
<a class="nav-link sh-nav-link"
   asp-controller="Home"
   asp-action="Index">
Начало
</a>
</li>

<li class="nav-item">
<a class="nav-link sh-nav-link"
   asp-controller="Services"
   asp-action="Index">
Услуги
</a>
</li>

<li class="nav-item">
<a class="nav-link sh-nav-link"
   asp-controller="Home"
   asp-action="About">
За нас
</a>
</li>

<li class="nav-item">
<a class="nav-link sh-nav-link"
   asp-controller="Home"
   asp-action="Contacts">
Контакти
</a>
</li>

</ul>



<!-- LOGIN -->

<div class="sh-auth">
<partial name="_LoginPartial"/>
</div>

</div>

</nav>

</header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   <footer class="sh-footer mt-5">
    <div class="container py-4">
        <div class="row g-4 align-items-start">

            <div class="col-md-5">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <img src="~/images/logo.png" alt="Logo" class="sh-footer-logo" />
                    <div>
                        <div class="sh-footer-title">SH Beauty Salon</div>
                        <div class="sh-footer-subtitle">Chic &amp; Unique</div>
                    </div>
                </div>

                <div class="sh-footer-text">
                    Добре дошли в нашето уютно място за красота и релакс.
                </div>
            </div>

            <div class="col-md-4">
                <div class="sh-footer-heading">Контакти</div>
                <div class="sh-footer-text">
                    <div><i class="fa-solid fa-location-dot me-2"></i>гр. София, ул. „Граф Игнатиев“ №27</div>
                    <div class="mt-2"><i class="fa-solid fa-phone me-2"></i>088 214 9331</div>
                    <div class="mt-2"><i class="fa-solid fa-envelope me-2"></i>shbeautystudioo@gmail.com</div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="sh-footer-heading">Социални мрежи</div>

                <div class="d-flex flex-column gap-2">
                    <a class="sh-social" href="#" target="_blank">
                        <i class="fa-brands fa-facebook"></i>
                        <span><strong>Facebook:</strong> SH Beauty Studio</span>
                    </a>

                    <a class="sh-social" href="#" target="_blank">
                        <i class="fa-brands fa-instagram"></i>
                        <span><strong>Instagram:</strong> shbeautystudio</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="sh-footer-bottom mt-4 pt-3">
            
            <span class="sh-footer-dot"></span>
            
        </div>
    </div>
</footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/animations.js"></script>
    <script src="~/js/slider.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    

</body>
</html>
